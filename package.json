{
  "name": "omnix",
  "version": "0.2.0",
  "author": "Dustin Lee/LemOne Labs",
  "description": "",
  "type": "module",
  "bin": {
    "omnix": "./dist/cli.js"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "engine": "tsx server.ts",
    "cli": "tsx src/cli/index.ts",
    "ui:dev": "vite",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "desktop": "concurrently \"npm run engine\" \"wait-on tcp:9777 && electron .\"",
    "build": "npm run build:ui && npm run build:server && npm run build:cli",
    "build:ui": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:@huggingface/transformers --external:onnxruntime-node --external:express --external:ws --external:cors --external:multer --external:kokoro-js --external:commander --external:node-fetch",
    "build:cli": "esbuild src/cli/index.ts --bundle --platform=node --format=esm --outfile=dist/cli.js --external:commander --external:node-fetch",
    "build:electron": "npm run build:ui && npm run build:server && npm run build:cli && electron-builder"
  },
  "build": {
    "appId": "com.omnix.studio",
    "productName": "Omnix",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "artifactName": "omnix.exe"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.3",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.9",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@huggingface/transformers": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "node-fetch": "^3.3.2",
    "onnxruntime-node": "^1.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.18.0"
  }
}
